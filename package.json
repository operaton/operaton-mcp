{
  "name": "operaton-mcp",
  "version": "1.1.0",
  "description": "MCP server exposing the full Operaton BPMN/DMN REST API to AI assistants",
  "type": "module",
  "access": "public",
  "main": "dist/index.js",
  "license": "Apache-2.0",
  "homepage": "https://github.com/operaton/operaton-mcp#readme",
  "bugs": {
    "url": "https://github.com/operaton/operaton-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/operaton/operaton-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "operaton",
    "bpmn",
    "dmn",
    "workflow",
    "workflow-automation",
    "camunda",
    "ai",
    "llm",
    "typescript"
  ],
  "bin": {
    "operaton-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare": "npm run generate && tsc && tsc-alias",
    "build": "npm run generate && tsc && tsc-alias",
    "generate": "node --import tsx/esm scripts/generate.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:smoke": "vitest run test/smoke",
    "test:integration": "vitest run test/integration",
    "typecheck": "tsc --noEmit",
    "check:license": "node --import tsx/esm scripts/check-license.ts",
    "add:license": "node --import tsx/esm scripts/add-license.ts",
    "check:commits": "commitlint --config commitlint.config.ts --from HEAD~1 --to HEAD"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "msw": "^2.12.13",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  }
}
