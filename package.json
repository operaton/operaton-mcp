{
  "name": "@operaton/operaton-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Operaton BPM REST API — exposes 300+ Operaton REST API operations as MCP tools for AI agents",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/operaton/operaton-mcp.git"
  },
  "keywords": ["mcp", "operaton", "bpm", "bpms", "process-automation", "claude"],
  "bin": {
    "operaton-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare": "npm run generate && tsc && tsc-alias",
    "build": "npm run generate && tsc && tsc-alias",
    "generate": "node --import tsx/esm scripts/generate.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:smoke": "vitest run test/smoke",
    "test:integration": "vitest run test/integration",
    "typecheck": "tsc --noEmit",
    "check:license": "node --import tsx/esm scripts/check-license.ts",
    "add:license": "node --import tsx/esm scripts/add-license.ts",
    "check:commits": "commitlint --config commitlint.config.ts --from HEAD~1 --to HEAD"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
